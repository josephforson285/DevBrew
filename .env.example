# DevBrew environment configuration
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is gitignored. NEVER commit real credentials.

# MongoDB Atlas connection string (mongodb+srv://...). Leave empty to run
# without a database (uses the in-memory repository for local/dev/CI).
MONGODB_URI=

# Database name used inside the cluster.
MONGODB_DB=devbrew

# Application environment: development | test | production
DEVBREW_ENV=development
